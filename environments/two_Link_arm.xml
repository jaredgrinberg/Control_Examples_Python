<mujoco model="two_link_arm">
  <compiler angle="radian"/>
  
  <option timestep="0.002" gravity="0 0 -9.81"/>
  
  <default>
    <joint damping="0.5" armature="0.01"/>
    <geom type="capsule" rgba="0.8 0.6 0.4 1" contype="1" conaffinity="1"/>
  </default>
  
  <worldbody>
    <body name="base" pos="0 0 1.0">
      <geom type="cylinder" size="0.05 0.02" rgba="0.3 0.3 0.3 1"/>
      
      <body name="link1" pos="0 0 0">
        <joint name="shoulder" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
        <geom fromto="0 0 0 0.3 0 0" size="0.02" rgba="0.8 0.2 0.2 1"/>
        <geom type="sphere" pos="0.15 0 0" size="0.03" rgba="0.6 0.1 0.1 1" mass="0.5"/>
        
        <body name="link2" pos="0.3 0 0">
          <joint name="elbow" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
          <geom fromto="0 0 0 0.25 0 0" size="0.018" rgba="0.2 0.8 0.2 1"/>
          <geom type="sphere" pos="0.125 0 0" size="0.025" rgba="0.1 0.6 0.1 1" mass="0.3"/>
          
          <body name="end_effector" pos="0.25 0 0">
            <geom type="sphere" size="0.03" rgba="1 1 0 1"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  
  <actuator>
    <general name="shoulder_torque" joint="shoulder" dyntype="none" biastype="none" gainprm="1" ctrllimited="true" ctrlrange="-20 20"/>
    <general name="elbow_torque" joint="elbow" dyntype="none" biastype="none" gainprm="1" ctrllimited="true" ctrlrange="-20 20"/>
  </actuator>
</mujoco>